{
  "include": ["src/**/*.ts", "spec/**/*.ts", "types"],
  "exclude": ["node_modules", "build", "dist", "out", "frontend/**/*"],

  "compilerOptions": {
    "types": ["vitest/globals"],

    "rootDir": ".",
    "outDir": "../../out/server",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "noEmitOnError": true,
    "allowJs": true,
    "checkJs": true,

    // "typeRoots": ["../../node_modules/@types", "../../node_modules", "./types"],
    // "types": ["vitest/globals", "node"],

    //===== Type checking =====
    "strict": true,
    "strictPropertyInitialization": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    // "allowUnreachableCode": false,
    // "allowUnusedLabels": false,
    "noUnusedParameters": true, // ПОТОМ ВКЛЮЧИТЬ!!!!
    "noUnusedLocals": true, // ПОТОМ ВКЛЮЧИТЬ!!!!
    "noImplicitAny": false,
    "strictNullChecks": true, // уже всегда включен в "strict": true

    //===== Interoperability: help external tools =====
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "isolatedModules": true,
    // "isolatedDeclarations": true,

    // "allowSyntheticDefaultImports": true,

    //===== Output: JavaScript =====
    "resolveJsonModule": true,
    "noUncheckedSideEffectImports": true, // warn on import 'foo.ts'
    "skipLibCheck": true, // ignore .d.ts at node_modules/
    // "esModuleInterop": true, // для компиляции ts в cjs
    // "moduleResolution": "nodenext", module "nodenext" sets it up automatic
    "module": "nodenext",
    "target": "esnext"
  }
}
