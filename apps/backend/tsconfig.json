{
  "compilerOptions": {
    "target": "es2024",
    "module": "nodenext",
    "outDir": "../../build/server",
    "rootDir": "./",
    "checkJs": false,
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "noEmitOnError": true,
    "noEmit": false,
    "sourceMap": false,
    "declarationMap": false,
    "declaration": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": false,
    "removeComments": true
  },
  "include": ["src/**/*.ts", "spec/**/*.ts", "types"],
  "exclude": ["node_modules", "build", "dist", "frontend/**/*"]
}
