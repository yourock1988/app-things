{
  "/api/v0/accounts": {
    "admin": ["GET", "POST"]
  },
  "/api/v0/accounts/:id": {
    "admin": ["GET", "PATCH", "DELETE"]
  },
  "/api/v0/sessions": {
    "admin": ["GET", "POST"]
  },
  "/api/v0/sessions/:id": {
    "admin": ["GET", "PATCH", "DELETE"]
  },
  "/api/v0/cars": {
    "admin": ["GET", "POST"],
    "user": ["GET"]
  },
  "/api/v0/cars/:id": {
    "admin": ["GET", "PATCH", "DELETE"],
    "user": ["GET"]
  },
  "/api/v0/users": {
    "admin": ["GET", "POST"],
    "user": ["GET"]
  },
  "/api/v0/users/:id": {
    "admin": ["GET", "PATCH", "DELETE"],
    "user": ["GET"]
  },
  "/cars": {
    "admin": [
      "authorization",
      "car:getAll",
      "car:getById",
      "car:add",
      "car:updateById",
      "car:removeById"
    ],
    "user": ["authorization", "car:getAll", "car:getById"]
  },
  "/users": {
    "admin": [
      "authorization",
      "user:getAll",
      "user:getById",
      "user:add",
      "user:updateById",
      "user:removeById"
    ],
    "user": ["authorization", "user:getAll", "user:getById"]
  }
}
