{
  "name": "@app-x/backend",
  "version": "0.0.1",
  "description": "backend",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "lint:js": "eslint ./src",
    "lint-staged": "lint-staged",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "ts": "npx tsc --watch",
    "swc": "node --env-file=../../.env.dev --watch --import @swc-node/register/esm src/main.ts",
    "swc:build": "swc src --copy-files --strip-leading-paths --delete-dir-on-start --out-file-extension ts -d ../../build/server --source-maps",
    "swc:dist": "swc src --copy-files --strip-leading-paths --delete-dir-on-start --out-file-extension ts -d ../../dist/server",
    "static:build": "cp -R ./static ../../build/server/static",
    "static:dist": "cp -R ./static ../../dist/server/static",
    "start:test": "node --env-file=../../.env.test ../../dist/server/main.ts",
    "start": "node --env-file=../../.env.prod ../../dist/server/main.ts",
    "build": "run-s swc:build static:build",
    "dist": "run-s swc:dist static:dist",
    "dev": "run-p swc ts"
  },
  "lint-staged": {
    "*.js": "eslint"
  },
  "eslintConfig": {
    "extends": [
      "../../packages/eslint-config/node.json"
    ]
  },
  "dependencies": {
    "@app-x/cmd": "^0.0.1",
    "@types/express-serve-static-core": "^5.1.1",
    "@yourock88/bind-self": "^0.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "libphonenumber-js": "^1.12.27",
    "socket.io": "^4.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.32",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/node": "^24.1.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "supertest": "^7.2.2",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  }
}
